{
  "name": "live-poll-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native",
    "build:contracts": "stellar contract build --manifest-path ../live-poll-contract/Cargo.toml --out-dir ../live-poll-contract/dist",
    "lint": "eslint .",
    "prepare:contracts": "npm run build:contracts && npm run refresh:contract-client",
    "preview": "vite preview --configLoader native",
    "refresh:contract-client": "stellar contract bindings typescript --wasm ../live-poll-contract/dist/hello_world.wasm --output-dir ./packages/live-poll-contract --overwrite"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.1.0",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^15.0.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "buffer": "^6.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
